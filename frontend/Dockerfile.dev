# Modern Node.js környezet az Angular 21-hez
FROM node:22-alpine AS dev

WORKDIR /app

# Angular CLI globális telepítése a konténerben
RUN npm install -g @angular/cli@21

# Exponáljuk az alapértelmezett Angular portot
EXPOSE 4200

# Az ng serve a --poll paraméterrel biztosítja, hogy a Docker volume-on
# keresztül is azonnal érzékelje a fájl módosításokat (Windows/Mac hálózati fájlrendszer miatt fontos)
CMD ["sh", "-c", "npm install && ng serve --host 0.0.0.0 --poll 2000"]